{
  "id": "page.codeberg.censor.Censor",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "censor",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland"
  ],
  "modules": [
    "python3-pymupdf.json",
    {
      "name": "censor",
      "builddir": true,
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://codeberg.org/censor/Censor.git",
          "branch": "main"
        }
      ]
    },
    {
      "name": "compileall",
      "buildsystem": "simple",
      "build-commands": [
        "python -m compileall -q --invalidation-mode=unchecked-hash /app/share/censor /app/lib/python*"
      ],
      "sources": [
        {
          "commit": "c2b3f7ff8441daab9b283871d69ac507dbdc267c"
        }
      ]
    }
  ]
}
