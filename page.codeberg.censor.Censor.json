{
  "id": "page.codeberg.censor.Censor",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "censor",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    "python3-pymupdf.json",
    {
      "name": "licenses-agpl",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 agpl-3.0.txt /app/share/licenses/page.codeberg.censor.Censor/AGPL-3.0-only.txt"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://www.gnu.org/licenses/agpl-3.0.txt",
          "sha256": "0d96a4ff68ad6d4b6f1f30f713b18d5184912ba8dd389f86aa7710db079abcb0"
        }
      ]
    },
    {
      "name": "censor",
      "builddir": true,
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://codeberg.org/censor/Censor.git",
          "tag": "v0.3.0",
          "commit": "222b0e65459ea1dff7560430392966ec7bc4bdc9"
        }
      ]
    }
  ]
}
